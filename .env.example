# LLM keys (only needed for cloud providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local model host
OLLAMA_BASE_URL=http://localhost:11434

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional runtime overrides
POLY_BANKROLL_USD=10000
POLY_EDGE_THRESHOLD=0.08
POLY_KELLY_FRACTION=0.25
POLY_LLM_PROVIDER=ollama
POLY_LLM_MODEL=llama3.1:70b
POLY_DRY_RUN=true
POLY_EXECUTION_ENABLED=false
POLY_TELEGRAM_ENABLED=false
